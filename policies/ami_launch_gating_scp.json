{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyRunInstancesUnlessAMIVetted",
      "Effect": "Deny",
      "Action": "ec2:RunInstances",
      "Resource": "arn:aws:ec2:*::image/*",
      "Condition": {
        "StringNotEquals": {
          "ec2:ResourceTag/attest:vetted": "true"
        }
      }
    }
  ]
}
