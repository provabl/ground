{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyMissingTagEnvironmentId",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "s3:CreateBucket",
        "rds:CreateDBInstance",
        "sagemaker:CreateNotebookInstance",
        "sagemaker:CreateTrainingJob"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/attest:environment-id": "true"
        }
      }
    },
    {
      "Sid": "DenyMissingTagDataClasses",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "s3:CreateBucket",
        "rds:CreateDBInstance",
        "sagemaker:CreateNotebookInstance",
        "sagemaker:CreateTrainingJob"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/attest:data-classes": "true"
        }
      }
    },
    {
      "Sid": "DenyMissingTagComplianceTier",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "s3:CreateBucket",
        "rds:CreateDBInstance",
        "sagemaker:CreateNotebookInstance",
        "sagemaker:CreateTrainingJob"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/attest:compliance-tier": "true"
        }
      }
    },
    {
      "Sid": "DenyMissingTagOUPath",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "s3:CreateBucket",
        "rds:CreateDBInstance",
        "sagemaker:CreateNotebookInstance",
        "sagemaker:CreateTrainingJob"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/attest:ou-path": "true"
        }
      }
    },
    {
      "Sid": "DenyMissingTagOwner",
      "Effect": "Deny",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "s3:CreateBucket",
        "rds:CreateDBInstance",
        "sagemaker:CreateNotebookInstance",
        "sagemaker:CreateTrainingJob"
      ],
      "Resource": "*",
      "Condition": {
        "Null": {
          "aws:RequestTag/attest:owner": "true"
        }
      }
    }
  ]
}
